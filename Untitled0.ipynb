        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "x = np.linspace(0, 10, 100)\n",
        "y = np.sin(x)\n",
        "\n",
        "plt.plot(x, y)\n",
        "plt.title(\"Mi primera curva\")\n",
        "plt.savefig(\"laura_practica.jpg\")\n",
        "plt.show()"
      ],
